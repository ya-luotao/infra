# ------------------------------------------- Required block -----------------------------------------------------------
# These variables are required and don't have default values
# You must provide values for these to run the deployment successfully

AWS_PROFILE=
AWS_ACCOUNT_ID=
AWS_REGION=

# your domain or subdomain name, eg great-innovations.dev, e2b.great-innovations.dev
DOMAIN_NAME=

# ------------------------------------------- Required with defaults ---------------------------------------------------
# These variables need to be specified but have default values

PROVIDER=aws
# prefix identifier for all resources
PREFIX=e2b-

# prod, staging, dev
TERRAFORM_ENVIRONMENT=dev

# ------------------------------------------- Optional block -----------------------------------------------------------
# Following variables are optional and doesn't have to be set

# Sandbox firewall: comma-separated CIDRs to allow through the private-range deny list
# ALLOW_SANDBOX_INTERNAL_CIDRS=

# ------------------------------------------- Multiple stacks in one AWS account ---------------------------------------
# To run more than one E2B deployment in the SAME AWS account, give each stack
# its own .env.<env> with DISTINCT values for ALL of the following. They are not
# optional for a second stack — leaving any at its default collides with the
# existing deployment.
#
#   PREFIX               - already above; must be unique (namespaces ~all named
#                          resources: S3 data buckets, ECR repos, IAM roles,
#                          Secrets Manager entries, ALB/SG, Nomad/Consul, ...).
#   DOMAIN_NAME          - already above; must be a DIFFERENT domain/subdomain.
#                          Each stack owns the wildcard *.DOMAIN_NAME DNS records
#                          and an ACM cert keyed on the domain in Cloudflare, so
#                          two stacks cannot share a domain. PREFIX does NOT help
#                          here.
#   TERRAFORM_STATE_KEY  - S3 key for this stack's Terraform state. Defaults to
#                          terraform/orchestration/state. Two stacks sharing it
#                          would read/overwrite each other's state. Set e.g.:
# TERRAFORM_STATE_KEY=terraform/orchestration/team2/state
#
# Optional (only needed if the two VPCs must peer/route to each other; two fully
# independent stacks can keep overlapping CIDRs). Subnets are derived from this.
# Use a /16. Default 10.0.0.0/16 reproduces the historical subnet layout.
# VPC_CIDR=10.1.0.0/16
